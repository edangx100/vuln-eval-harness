# Copy to .env and fill in.

# --- Required ---

# Host-only credential. Never passed into the Docker sandbox.
OPENROUTER_API_KEY=your_key_here

# Exact OpenRouter model id for this run.
# Reference runs: deepseek/deepseek-v4-flash, deepseek/deepseek-v4-pro
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Identifies this run's result file, e.g. results/<RUN_NAME>.json.
RUN_NAME=deepseek-v4-flash

# --- Optional (defaults shown) ---

# Primary effort bound: max tool-call steps per case.
MAX_TOOL_CALL_STEPS=15

# Backstop effort bound: per-case wall-clock timeout, in seconds.
CASE_TIMEOUT_SECONDS=120

# Independent agent attempts per case (trial-averaged, not best-of-N).
ATTEMPTS_PER_CASE=3
